# Django
SECRET_KEY=django-insecure-CHANGEZ-MOI-en-production-!@#$%^&*()
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# Base de données (laisser vide pour SQLite en développement)
